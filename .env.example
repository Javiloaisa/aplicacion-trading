# ── Fuente de datos ───────────────────────────────────────────
BITUNIX_BASE_URL=https://fapi.bitunix.com
# Multi-par: las 10 cripto más fuertes (por capitalización) con futuros USDT en
# Bitunix. Edita la lista (separada por comas) para vigilar otras.
SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,TRXUSDT,AVAXUSDT,LINKUSDT
# Multi-timeframe: cada símbolo se evalúa en TODAS estas temporalidades (coma-separadas).
TIMEFRAMES=1h,4h
KLINES_LIMIT=200
POLL_INTERVAL_SEC=60

# ── Indicadores ───────────────────────────────────────────────
RSI_PERIOD=14
RSI_LONG_LEVEL=30
RSI_SHORT_LEVEL=70
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
# Exigir además línea MACD > señal (long) / < señal (short). El cruce del
# histograma ya lo implica casi siempre -> por defecto apagado.
MACD_REQUIRE_ABOVE_SIGNAL=false

# ── Niveles soporte/resistencia (swing high/low) ──────────────
SWING_N=20

# ── Lógica R (aviso, no ejecución) ────────────────────────────
RISK_USDT=10
LEVERAGE=10
STOP_BUFFER_PCT=0.001

# ── Telegram ──────────────────────────────────────────────────
# DESACTIVADO: los avisos van SOLO al móvil por Web Push (server.py no usa
# Telegram). Estas variables solo las lee main.py en modo standalone; déjalas
# vacías para no enviar nada por Telegram.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── App web / PWA / Web Push ──────────────────────────────────
APP_NAME=Crypto Signals
WEB_HOST=0.0.0.0
WEB_PORT=8095
PUSH_ENABLED=true
# Se autogenera al primer arranque si no existe. NO lo borres ni lo subas a git.
VAPID_PRIVATE_KEY_FILE=vapid_private.pem
# Contacto que el push service usa si hay problemas (mailto: o URL). Pon tu email.
VAPID_SUBJECT=mailto:admin@example.com
SUBSCRIPTIONS_FILE=subscriptions.json
SIGNALS_FILE=signals.json

# ── Estado ────────────────────────────────────────────────────
STATE_FILE=state.json
